<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chess Arena</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            background: #2a2520;
            min-height: 100vh;
            overflow-x: hidden;
        }

        .chessboard {
            display: grid;
            grid-template-columns: repeat(8, 1fr);
            grid-template-rows: repeat(8, 1fr);
            width: 480px;
            height: 480px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.12);
            border-radius: 8px;
            overflow: hidden;
        }

        .piece.white {
            color: #f5f5f5;
            filter: drop-shadow(0 0 3px rgba(0, 0, 0, 0.8)) drop-shadow(0 2px 4px rgba(0, 0, 0, 0.6));
            text-shadow: 0 0 2px rgba(0, 0, 0, 0.9), 0 1px 2px rgba(0, 0, 0, 0.8);
        }

        .piece.black {
            color: #1a1a1a;
            filter: drop-shadow(0 2px 4px rgba(255, 255, 255, 0.1));
        }

        .square {
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background-color 0.2s ease;
        }

        .square.light {
            background-color: #ede6d3;
        }

        .square.dark {
            background-color: #8b7355;
        }

        .square:hover {
            filter: brightness(1.05);
        }

        .piece {
            font-size: 48px;
            cursor: pointer;
            user-select: none;
        }

        .piece.draggable {
            cursor: grab;
        }

        .piece.draggable:active {
            cursor: grabbing;
        }

        .dragging {
            opacity: 0.6;
        }

        /* Modal Styles */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            z-index: 1000;
            align-items: center;
            justify-content: center;
        }

        .modal.active {
            display: flex;
        }

        .modal-content {
            background: #3a3530;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            max-width: 400px;
            width: 90%;
            border: 1px solid #4a4540;
        }

        .modal-content h2 {
            color: #f5f1ed;
            margin-bottom: 10px;
            font-size: 24px;
            font-weight: 600;
        }

        .modal-content p {
            color: #c9bfb5;
            margin-bottom: 24px;
            font-size: 14px;
        }

        .modal-content input {
            width: 100%;
            padding: 12px 16px;
            border: 1px solid #5a5550;
            background: #2a2520;
            color: #f5f1ed;
            border-radius: 6px;
            font-size: 14px;
            margin-bottom: 20px;
            transition: border-color 0.2s ease;
        }

        .modal-content input:focus {
            outline: none;
            border-color: #d4a574;
            background: #322d28;
        }

        .modal-content button {
            width: 100%;
            padding: 12px 16px;
            background: #b8956a;
            color: #1a1815;
            border: none;
            border-radius: 6px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.2s ease;
        }

        .modal-content button:hover {
            background: #d4a574;
        }

        .player-info {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px;
            background: #3a3530;
            border-radius: 6px;
            margin-bottom: 12px;
            border-left: 3px solid #d4a574;
        }

        .player-badge {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 12px;
            color: white;
        }

        .player-badge.white {
            background: #d4a574;
            color: #1a1815;
        }

        .player-badge.black {
            background: #5a5550;
            border: 2px solid #d4a574;
        }

        .player-badge.spectator {
            background: #8b7f77;
        }

        .player-info-text {
            flex: 1;
        }

        .player-name {
            color: #f5f1ed;
            font-weight: 600;
            font-size: 13px;
        }

        .player-role {
            color: #9a8f87;
            font-size: 11px;
            margin-top: 2px;
        }

        .chat-message {
            border-radius: 6px;
            padding: 10px 12px;
            font-size: 13px;
            background: #2a2520;
            border-left: 3px solid #d4a574;
            margin-bottom: 8px;
        }

        .chat-message-sender {
            color: #d4a574;
            font-weight: 600;
            font-size: 12px;
        }

        .chat-message-time {
            color: #9a8f87;
            font-size: 11px;
            margin-left: 8px;
        }

        .chat-message-text {
            color: #f5f1ed;
            margin-top: 4px;
            word-break: break-word;
        }

        .section-title {
            color: #9a8f87;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
            margin-top: 12px;
        }

        .section-title:first-child {
            margin-top: 0;
        }

        input::placeholder {
            color: #7a6f68;
        }

        button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        /* Mobile */
        @media (max-width: 768px) {
            #gameContainer .flex {
                flex-direction: column !important;
            }

            .w-80 {
                width: 100% !important;
            }

            .chessboard {
                width: 300px;
                height: 300px;
                margin: 0 auto;
            }

            .piece {
                font-size: 32px;
            }

            .modal-content {
                padding: 25px 15px;
            }

            .modal-content h2 {
                font-size: 18px;
            }

            .player-info, .chat-message {
                padding: 8px;
                font-size: 12px;
            }

            #chatForm input, #chatForm button {
                font-size: 12px;
                padding: 8px;
            }
        }
    </style>
</head>
<body>
    <!-- Name Modal -->
    <div id="nameModal" class="modal active">
        <div class="modal-content">
            <h2>Welcome to Chess Arena</h2>
            <p>Enter your name to join the game</p>
            <input id="playerNameInput" type="text" placeholder="Your name" maxlength="20" />
            <button id="startGameBtn">Start Playing</button>
        </div>
    </div>

    <!-- Main Game Container -->
    <div id="gameContainer" class="hidden w-full h-screen flex flex-col">
        <!-- Header -->
        <div style="background: #3a3530; border-bottom: 1px solid #4a4540;" class="px-6 py-4 shadow-sm">
            <div class="max-w-7xl mx-auto">
                <h1 class="text-2xl font-bold" style="color: #f5f1ed;">♟ Chess Arena</h1>
            </div>
        </div>

        <!-- Main Content -->
        <div class="flex-1 overflow-hidden">
            <div class="max-w-7xl mx-auto h-full flex gap-6 p-6">
                <!-- Left: Chat -->
                <div style="background: #3a3530; border: 1px solid #4a4540;" class="w-80 rounded-lg p-4 flex flex-col shadow-sm">
                    <div class="section-title">Game Chat</div>
                    <div id="chatMessages" class="flex-1 overflow-y-auto space-y-2 mb-4 pr-2"></div>
                    <form id="chatForm" class="space-y-2">
                        <input id="chatText" type="text" placeholder="Type a message..." style="border: 1px solid #5a5550; background: #2a2520; color: #f5f1ed;" class="w-full rounded-md px-3 py-2 text-sm focus:outline-none" />
                        <button type="submit" style="background: #b8956a; color: #1a1815;" class="w-full rounded-md px-4 py-2 text-sm font-medium hover:opacity-90 transition">Send</button>
                    </form>
                </div>

                <!-- Center: Board -->
                <div class="flex flex-col gap-4 flex-1 flex items-center justify-center">
                    <div class="chessboard"></div>
                </div>

                <!-- Right: Players and Spectators -->
                <div class="w-80 flex flex-col gap-6">
                    <!-- Players Section -->
                    <div style="background: #3a3530; border: 1px solid #4a4540;" class="rounded-lg p-4 shadow-sm">
                        <div class="section-title">Players</div>
                        <div id="playersContainer" class="space-y-2">
                            <div style="color: #9a8f87;" class="text-sm">Waiting for players...</div>
                        </div>
                    </div>

                    <!-- Spectators Section -->
                    <div style="background: #3a3530; border: 1px solid #4a4540;" class="rounded-lg p-4 shadow-sm flex-1 overflow-y-auto">
                        <div class="section-title">Spectators</div>
                        <div id="spectatorsContainer" class="space-y-2">
                            <div style="color: #9a8f87;" class="text-sm">No spectators yet</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.socket.io/4.8.3/socket.io.min.js" integrity="sha384-kzavj5fiMwLKzzD1f8S7TeoVIEi7uKHvbTA3ueZkrzYq75pNQUiUi6Dy98Q3fxb0" crossorigin="anonymous"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/chess.js/0.10.3/chess.min.js" integrity="sha512-xRllwz2gdZciIB+AkEbeq+gVhX8VB8XsfqeFbUh+SzHlN96dEduwtTuVuc2u9EROlmW9+yhRlxjif66ORpsgVA==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script src="/Js/chessgame.js" type="application/javascript"></script>
</body>
</html>